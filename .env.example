# Copy to .env and fill in real values. NEVER commit .env to git.

# Zerodha Kite Connect credentials
Kite__ApiKey=your_kite_api_key
Kite__ApiSecret=your_kite_api_secret

# JWT signing key — generate with: openssl rand -base64 64
Jwt__SigningKey=change_me_use_openssl_rand_base64_64

# Operator login password for the web UI
Operator__Password=changeme

# Database
ConnectionStrings__Db=Host=db;Database=thetadesk;Username=thetadesk;Password=localdev
ConnectionStrings__Redis=redis:6379

# Postgres password (must match ConnectionStrings__Db above)
POSTGRES_PASSWORD=localdev
